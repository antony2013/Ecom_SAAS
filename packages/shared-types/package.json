{
  "name": "@repo/shared-types",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./schemas": {
      "types": "./src/schemas/index.ts",
      "default": "./src/schemas/index.ts"
    },
    "./types": {
      "types": "./src/types/index.ts",
      "default": "./src/types/index.ts"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "echo 'shared-types: no build needed'",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "zod": "^4"
  },
  "devDependencies": {
    "typescript": "^5.8.0"
  }
}